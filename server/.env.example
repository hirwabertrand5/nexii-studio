PORT=5000

# Database
MONGO_URI=mongodb+srv://nexii_user:your_password@cluster0.xxxxx.mongodb.net/nexii_studio?retryWrites=true&w=majority

# Authentication & Security
JWT_SECRET=your_secure_secret_key_minimum_32_characters_long
DOWNLOAD_TOKEN_SECRET=your_download_token_secret

# CORS & Frontend
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Admin Setup
ADMIN_EMAIL=admin@nexii-studio.com

# File Upload - Cloudinary (Images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# File Upload - AWS S3 (Documents)
AWS_REGION=us-east-1
S3_BUCKET=nexii-studio-dev
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Payment Gateways
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key
FLUTTERWAVE_WEBHOOK_SECRET_HASH=your_flutterwave_webhook_secret_hash
